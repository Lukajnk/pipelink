# pipelink's default behaviour is the opposite of the values below so uncommenting alone changes behaviour

# silent_warning="true"		# hide pipelink warnings
# clear_mode="true"		# clears screen on start
# link_mode="false"		# hides pipeline url
# monitor_mode="false"		# hides jobs status
# once_mode="true"		# shows jobs status once and stops
# small_mode="false"		# single line jobs status with emojis
# emoji_mode="true"		# enable emojis
# colored_mode="false"		# disable colors
# interval=1			# change jobs status interval period (default is 3 seconds)
